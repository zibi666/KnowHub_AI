APP_ENV=development
APP_BASE_DOMAIN=localhost
APP_SESSION_COOKIE_NAME=sid
APP_CSRF_COOKIE_NAME=csrf_token

# Required before production use. Generate with:
# python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
APP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
APP_ENCRYPTION_KEY_NEXT=

ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=ChangeMe123!
SESSION_TTL_DAYS=7

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_URL=redis://redis:6379/1

MODEL_BASE_URL=https://nexor.nexoraivision.com/v1
MODEL_BASE_URL_ALLOWED_HOSTS=nexor.nexoraivision.com
MODEL_API_MODE=responses
MODEL_REASONING_EFFORT=medium
MODEL_REASONING_EFFORT_ALLOWED=low,medium,high,xhigh
MODEL_MAX_COMPLETION_TOKENS=1536
MODEL_MAX_COMPLETION_TOKENS_CEILING=8192
LONG_INPUT_TOKEN_THRESHOLD=8000
LONG_INPUT_MAX_COMPLETION_TOKENS=1024

COMPACTION_MODEL_PREFERRED=gpt-5.4-mini,gpt-4.1-mini
COMPACTION_MODEL_MAX_OUTPUT_TOKENS=1200
COMPACTION_USER_MESSAGE_INTERVAL=3
COMPACTION_SUMMARY_KEEP_RECENT_TURNS=1
COMPACTION_TRIGGER_RATIO=0.85
COMPACTION_FORCE_RATIO=0.90
COMPACTION_WAIT_MAX_SECONDS=3
MANUAL_COMPACTION_WAIT_SECONDS=10
COMPACTION_MIN_MESSAGES=5
COMPACTION_MIN_INTERVAL_MINUTES=10
COMPACTION_MAX_TOKENS=16000
COMPACTION_WATCHDOG_MINUTES=5
CONTEXT_TEXT_TOKEN_LIMIT=30000

ATTACHMENT_PARSE_TIMEOUT_SECONDS=60
ATTACHMENT_PENDING_TTL_HOURS=1
STS_TTL_MINUTES=30
ZOMBIE_SCAN_THRESHOLD_MINUTES=30
WORKER_GRACEFUL_SHUTDOWN_SECONDS=100
STREAM_PING_INTERVAL_SECONDS=15

LOCAL_STORAGE_ROOT=./data/local-storage
LOCAL_CACHE_ROOT=./data/cache
LOCAL_CACHE_MAX_GB=5
LOCAL_CACHE_MAX_FILE_MB=50
MAX_IMAGE_MB=5
MAX_DOCUMENT_MB=10
DEFAULT_USER_STORAGE_GB=2
VISION_MODEL_PATTERNS=gpt-4o,gpt-4.1,gpt-5,o3,o4,vision,vl,gemini,claude
VISION_IMAGE_MAX_EDGE=1024
VISION_IMAGE_JPEG_QUALITY=82
VISION_IMAGE_MAX_COUNT=4
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MAX_CHARS_PER_CHUNK=1800
EMBEDDING_CHUNK_OVERLAP_CHARS=200
RAG_TOP_K_PER_ATTACHMENT=5
RAG_MAX_CONTEXT_TOKENS=12000

WEB_SEARCH_ENABLED=false
WEB_SEARCH_SEARXNG_BASE_URL=
WEB_SEARCH_RESULT_COUNT=5
WEB_SEARCH_LANGUAGE=all
WEB_SEARCH_SAFESEARCH=1
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_FETCH_TIMEOUT_SECONDS=20
WEB_SEARCH_MAX_TOOL_CALLS=4
WEB_SEARCH_FETCH_MAX_CHARS=12000

# Optional Tencent COS fields. Leave blank for local filesystem storage.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=
COS_INTERNAL_ENDPOINT=
ALERT_WEBHOOK_URL=
